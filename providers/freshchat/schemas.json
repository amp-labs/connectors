        "accounts": {
          "displayName": "Account Configuration",
          "description": "Retrieves information pertaining to the account configured for an organization.",
          "path": "/v2/accounts/configuration",
          "httpMethod": "GET",
          "responseKey": "",
          "fields": {
            "organisation_id": {
              "displayName": "organisation_id",
              "valueType": "int",
              "providerType": "integer",
              "description": "Unique Identifier of an organization"
            },
            "organisation_domain": {
              "displayName": "organisation_domain",
              "valueType": "string",
              "providerType": "string",
              "description": "Full domain name of the organisation"
            },
            "account_id": {
              "displayName": "account_id",
              "valueType": "int",
              "providerType": "integer",
              "description": "Unique identifier for the Freshchat account"
            },
            "account_domain": {
              "displayName": "account_domain",
              "valueType": "string",
              "providerType": "string",
              "description": "Domain name of the Freshchat account"
            },
            "app_id": {
              "displayName": "app_id",
              "valueType": "string",
              "providerType": "string",
